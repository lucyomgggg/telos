# MISTRAL_API_KEY=
# COHERE_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=

# --- Local LLMs (Ollama) ---
# OLLAMA_API_BASE=http://localhost:11434

# --- Infrastructure ---
# QDRANT_URL=http://localhost:6333
# TELOS_HOME=~/.telos
